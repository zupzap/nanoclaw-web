
# Claude authentication (pick one)
# If using Claude Code, your OAuth token is passed automatically.
# Otherwise, set your Anthropic API key:
# ANTHROPIC_API_KEY=sk-ant-...
# For Claude Code users with OAuth:
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat...

# Web Chat
WEB_CHAT_PASSWORD=
WEB_CHAT_PORT=3100

# Autonomous X engagement loop — ssup browses X every 5-20 min,
# finds interesting tweets, and decides whether to engage.
# Requires X integration to be set up first (/x-integration).
X_AUTONOMOUS=true
